<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Deck" parent="android:Theme.Black.NoTitleBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/deck_bg</item>
        <item name="android:windowBackground">@color/deck_bg</item>
    </style>
    <style name="Theme.Deck.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/deck_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Deck</item>
    </style>
</resources>
